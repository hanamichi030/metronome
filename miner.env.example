# Poker44 miner config for THIS fork (uid239).
#   cp miner.env.example miner.env   # then fill in the values below
# Launch with the wrapper (it sources miner.env and pins the commit):
#   ./run_p44_miner.sh
# miner.env is gitignored so your local edits never collide with upstream.

# bittensor 10.x skips CLI arg parsing unless this is set false (then
# config.neuron is None -> startup AttributeError). Required for the 10.x
# stack pinned in requirements-model.txt (needed after the chain's NetUid
# runtime upgrade). Harmless on 9.x.
export BT_NO_PARSE_CLI_ARGS=false

# --- Wallet / chain (consumed by scripts/miner/run/run_miner.sh) ---
export WALLET_NAME="my_cold"
export HOTKEY="my_uid239_hotkey"
export AXON_PORT="8097"
export PM2_NAME="poker44_miner_uid239"
# Space-separated validator hotkeys allowed to query you (recommended).
# Leave empty to fall back to the validator-permit rule.
export ALLOWED_VALIDATOR_HOTKEYS=""

# --- Model identity (MUST match the public code you serve) ---
# Your OWN public fork — NEVER https://github.com/Poker44/Poker44-subnet
export POKER44_MODEL_REPO_URL="https://github.com/hanamichi030/metronome"
# Anything except the reserved name "poker44-reference-heuristic"
export POKER44_MODEL_NAME="poker239-irunion"
export POKER44_MODEL_VERSION="1"
export POKER44_MODEL_OPEN_SOURCE="true"
export POKER44_MODEL_TRAINING_DATA_STATEMENT="Soft-vote ensemble (ExtraTrees + RandomForest + HistGradientBoosting) over a 452-dim union order-statistic behavioral feature surface (cross-hand duplication signatures, entropies, structural and aggression aggregates), each feature mapped to its within-served-window percentile rank before the trees. Trained on the public Poker44 benchmark (labels from groundTruth); training hands pass through prepare_hand_for_miner so training matches serving. Output is a strictly-monotone, tie-free within-batch decision layer that lets the top ~10% of each batch cross 0.5. No isotonic calibration, no domain adaptation, and no query-chunk fitting are used."
export POKER44_MODEL_PRIVATE_DATA_ATTESTATION="No validator-only evaluation labels or private data are used. The model trains only on public Poker44 benchmark labels. No test-time domain adaptation or query-chunk fitting is applied; each received chunk is scored independently up to a within-served-window rank transform and a monotone output map."

# NOTE: POKER44_MODEL_REPO_COMMIT is set automatically by run_p44_miner.sh to the
# current git HEAD, so the served commit always matches the running code. Do not
# hand-set it here.
